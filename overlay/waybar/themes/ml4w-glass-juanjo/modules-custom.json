{
    // Temperatura CPU — script propio en vez del módulo `temperature` nativo.
    // El nativo obliga a fijar hwmon-path-abs, y esa ruta es justo lo que cambia entre equipos
    // (Intel coretemp ↔ AMD k10temp). El script resuelve el sensor por NOMBRE de hwmon, que
    // además es estable entre arranques (hwmonN no lo es). Umbral crítico: 85 °C.
    "custom/cputemp": {
        "exec": "~/.config/waybar/themes/ml4w-glass-juanjo/scripts/cputemp.sh",
        "return-type": "json",
        "interval": 5,
        "format": "{}",
        "tooltip": true,
        "on-click": "~/.config/ml4w/settings/system-monitor.sh"
    },
    // Temperatura GPU NVIDIA — script condicional: solo consulta nvidia-smi si la GPU ya está
    // despierta (runtime_status=active); si duerme (portátil Optimus), NO la despertamos.
    // La dirección PCI y el nombre de la tarjeta los resuelve el script, así que el tooltip
    // dice la GPU real de cada equipo (por eso ya no hay "tooltip-format" fijo aquí).
    "custom/gputemp": {
        "exec": "~/.config/waybar/themes/ml4w-glass-juanjo/scripts/gputemp.sh",
        "return-type": "json",
        "interval": 5,
        "format": "{}",
        "tooltip": true,
        "on-click": "~/.config/ml4w/settings/system-monitor.sh"
    },
    // Fondo de vídeo (mpvpaper) — botón toggle ON/OFF. No arranca con el sistema.
    // Al pulsar alterna mpvpaper y se autorefresca por señal (SIGRTMIN+8). Config del
    // vídeo/rotación en el propio script livewallpaper.sh.
    "custom/livewallpaper": {
        "exec": "~/.config/waybar/themes/ml4w-glass-juanjo/scripts/livewallpaper.sh status",
        "return-type": "json",
        "interval": "once",
        "signal": 8,
        "format": "{}",
        "tooltip": true,
        "on-click": "~/.config/waybar/themes/ml4w-glass-juanjo/scripts/livewallpaper.sh toggle"
    },
    // Luz nocturna (hyprsunset) — override manual sobre el horario de hyprsunset.conf.
    // Clic: alterna cálido/neutro. Clic derecho: devuelve el mando al horario.
    // interval (no "once"): el horario cambia solo a las 07:00/21:00 sin avisar a waybar,
    // así que hay que sondear; la señal solo cubre nuestras propias pulsaciones.
    "custom/nightlight": {
        "exec": "~/.config/waybar/themes/ml4w-glass-juanjo/scripts/nightlight.sh status",
        "return-type": "json",
        "interval": 30,
        "signal": 9,
        "format": "{}",
        "tooltip": true,
        "on-click": "~/.config/waybar/themes/ml4w-glass-juanjo/scripts/nightlight.sh toggle",
        "on-click-right": "~/.config/waybar/themes/ml4w-glass-juanjo/scripts/nightlight.sh schedule"
    }
}
