# Capa de seguridad: nunca versionar datos privados / secretos / temporales.
# El overlay solo debe contener theme (CSS/JSON/config) + scripts. Cualquier otra cosa,
# fuera del repo.

# Logs y backups de ML4W
*.log
backups/

# Secretos / credenciales
*.token
*.key
*.pem
*.p12
*.pfx
.env
.env.*

# Preferencias por máquina (monitor del fondo de vídeo, carpeta de vídeos). Viven en
# ~/.config/ml4w-juanjo/local.env y NO se versionan: el overlay es idéntico en todos los
# equipos y lo que cambia de uno a otro se queda fuera de git.
local.env
*_rsa
*_ed25519
id_*
*.gpg
secrets*
credentials*

# Temporales del editor / SO
*~
*.swp
*.swo
*.bak
*.orig
.DS_Store
